# Copy to .env and fill in. .env is gitignored.

# --- Claude access (via the `claude` CLI subprocess) ---
# The app shells out to the `claude` binary, which authenticates itself from
# ~/.claude/.credentials.json (run `claude login` once) or ANTHROPIC_API_KEY.
# There is no auth code in this app — see src/job_scout/claude_cli.py.

# Absolute path to the binary. REQUIRED for cron/systemd (their PATH is minimal
# and won't find a bare `claude`). Find it with: which claude
CLAUDE_PATH=/usr/local/bin/claude

# Optional: HOME override so the CLI finds the right ~/.claude when the app runs
# as a different OS user than the one that ran `claude login`.
# CLAUDE_HOME=/home/blake

# Optional: model to pass to `claude --model`. Leave unset to use the CLI default.
# JOB_SCOUT_MODEL=claude-opus-4-8

# Alternative to `claude login`: an API key the CLI will use instead (good for
# headless/containers). Leave unset if you authenticate via `claude login`.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Matching ---
# Jobs scoring at or above this (0-10) trigger an email alert.
ALERT_THRESHOLD=9

# --- Gmail SMTP (email alerts) ---
# Use a Gmail App Password, NOT your account password.
# https://support.google.com/accounts/answer/185833
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=
ALERT_RECIPIENT=you@gmail.com

# --- Paths ---
RESUME_PATH=data/resume.pdf
DB_PATH=data/job_scout.db
